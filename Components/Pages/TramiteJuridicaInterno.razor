    private void ToggleUrl() => mostrarUrl = !mostrarUrl;

    private void EliminarAnexo(MesaPartesDigital.Models.ArchivoAdjunto anexo) => anexosLista.Remove(anexo);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        errorArchivoPrincipal = "";
        archivo = e.File;

        if (archivo == null) return;

        if (archivo.ContentType != "application/pdf")
        {
            errorArchivoPrincipal = "Solo PDF.";
            archivo = null;
            pdfPreviewUrl = null;
            return;
        }

        try
        {
            using var stream = archivo.OpenReadStream(25 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            pdfPreviewUrl = $"data:application/pdf;base64,{Convert.ToBase64String(ms.ToArray())}";
        }
        catch (Exception ex)
        {
            errorArchivoPrincipal = $"Error al previsualizar PDF: {ex.Message}";
        }
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        if (anexosLista.Count >= 10) return;

        foreach (var file in e.GetMultipleFiles(10))
        {
            if (anexosLista.Count >= 10) break;
            if (file.Size > 20 * 1024 * 1024) continue;

            var extension = Path.GetExtension(file.Name).ToLower();
            var permitidos = new[] { ".pdf", ".docx", ".xlsx", ".ppt", ".jpg", ".png", ".zip" };
            if (!permitidos.Contains(extension)) continue;

            try
            {
                using var ms = new MemoryStream();
                await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);

                anexosLista.Add(new MesaPartesDigital.Models.ArchivoAdjunto
                {
                    Nombre = file.Name,
                    Tipo = extension,
                    Tamano = $"{file.Size / 1024} KB",
                    //Base64 = Convert.ToBase64String(ms.ToArray()),
                    // FileBrowser = file
                });
            }
            catch
            {
                // Manejo silencioso de fallas de lectura de archivos individuales
            }
        }
    }

