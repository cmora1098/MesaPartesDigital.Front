@page "/juridica"

@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject ApplicationDbContext DbContext 

@* 
@if (isProcessing)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center bg-white bg-opacity-75" style="z-index: 9999;">
        <div class="spinner-border text-success" role="status" style="width: 3rem; height: 3rem; color: #006432 !important;"></div>
        <h5 class="mt-3 text-dark fw-bold" style="font-family: sans-serif;">Procesando y registrando su trámite empresarial...</h5>
    </div>
}

<div class="ux-bg">
    <div class="ux-container">

        <div class="ux-header">
            <div class="ux-badge-top">Mesa de Partes Digital</div>
            <h1>Persona Jurídica</h1>
            <p class="ux-description">
                Completa los datos de la empresa y del documento para registrar el trámite institucional.
            </p>
        </div>

        <div class="ux-card-form">
            <h2>I. DATOS DE LA EMPRESA</h2>
            <div class="ux-grid-form">

                <div class="ux-field">
                    <label>RUC *</label>
                    <div class="ux-input-group">
                        <input @bind="rucInputValue" placeholder="Ingrese RUC" maxlength="11" onkeypress="return event.charCode >= 48 && event.charCode <= 57" disabled="@isProcessing" />
                        <button type="button" class="ux-button" @onclick="ValidarRuc" disabled="@isProcessing">Validar</button>
                    </div>
                    @if (!string.IsNullOrEmpty(rucErrorMsg) && bloqueadoRazonSocial)
                    {
                        <span class="ux-error">@rucErrorMsg</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Razón Social *</label>
                    <input @bind="razonSocialValue"
                           readonly="@bloqueadoRazonSocial"
                           class="@(bloqueadoRazonSocial ? "ux-readonly" : "")"
                           disabled="@isProcessing" />

                    @if (!string.IsNullOrEmpty(rucErrorMsg) && !bloqueadoRazonSocial)
                    {
                        <span class="ux-error">@rucErrorMsg</span>
                    }
                </div>

            </div>
        </div>

        <div class="ux-card-form">
            <h2>II. DATOS DEL DOCUMENTO</h2>
            <div class="ux-grid-form">

                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="formulario.ICodTipoDoc">
                        <option value="0">--SELECCIONAR--</option>
                        @foreach (var doc in listaTiposDocumento)
                        {
                            <option value="@doc.iCodTipoDoc">@doc.vNombreTipoDoc</option>
                        }
                    </select>
                    @if (mostrarErroresValidacion && formulario.ICodTipoDoc == 0)
                    {
                        <span class="ux-error">Seleccione el tipo de documento.</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Nro Documento *</label>
                    <input @bind="formulario.VNroDoc" style="text-transform: uppercase;" placeholder="Ej: OFICIO N° 012-2026-GG" />
                    @if (mostrarErroresValidacion && string.IsNullOrWhiteSpace(formulario.VNroDoc))
                    {
                        <span class="ux-error">El número de documento es obligatorio.</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Folio *</label>
                    <input @bind="formulario.VNroPagFolios" type="number" min="1" placeholder="Ej: 5" />
                    @if (mostrarErroresValidacion && (string.IsNullOrWhiteSpace(formulario.VNroPagFolios) || formulario.VNroPagFolios == "0"))
                    {
                        <span class="ux-error">Indique una cantidad válida de folios.</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Fecha del Documento *</label>
                    <input type="date" @bind="formulario.DFecDoc" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    @if (mostrarErroresValidacion && formulario.DFecDoc == default)
                    {
                        <span class="ux-error">La fecha del documento es requerida.</span>
                    }
                </div>

                <div class="ux-field full">
                    <label>Asunto / Sumilla *</label>
                    <textarea maxlength="255" @bind="asuntoDocumento" style="text-transform: uppercase;" placeholder="Ingrese la sumilla del trámite empresarial..."></textarea>
                    @if (mostrarErroresValidacion && string.IsNullOrWhiteSpace(asuntoDocumento))
                    {
                        <span class="ux-error">El asunto o sumilla es obligatorio.</span>
                    }
                </div>

                <div class="ux-field full">
                    <label>Referencia</label>
                    <input @bind="formulario.VReferencia" style="text-transform: uppercase;" placeholder="Ej: LICITACIÓN PÚBLICA N° 002-2026" />
                </div>

            </div>
        </div>

        <div class="ux-card-form">
            <h2>Documento adjunto</h2>

            <InputFile OnChange="OnFileSelected" accept=".pdf" class="ux-file" disabled="@isProcessing" />

            @if (archivo != null)
            {
                <p class="ux-success">@archivo.Name</p>

                @if (!string.IsNullOrEmpty(pdfPreviewUrl))
                {
                    <div class="ux-pdf-preview">
                        <iframe src="@pdfPreviewUrl"></iframe>
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(errorArchivoPrincipal))
            {
                <p class="ux-error">@errorArchivoPrincipal</p>
            }

            <div class="mt-3">
                <button type="button" class="ux-button-outline" @onclick="ToggleUrl" disabled="@isProcessing">
                    + Agregar URL
                </button>
            </div>

            @if (mostrarUrl)
            {
                <input class="ux-input-url" @bind="urlIngresada" placeholder="https://..." disabled="@isProcessing" />
            }
        </div>

        <div class="ux-card-form">
            <h2>Anexos</h2>
            <p class="ux-help">
                (Peso máximo de cada archivo: 20MB)<br />
                (Formatos permitidos: PDF, DOCX, XLSX, PPT, JPG, PNG y ZIP)<br />
                (Número máximo de anexos: 10)
            </p>

            <InputFile OnChange="HandleFilesSelected" multiple class="ux-file" disabled="@isProcessing" />

            <div class="ux-table-wrapper">
                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (anexosLista.Any())
                        {
                            @foreach (var item in anexosLista)
                            {
                                <tr>
                                    <td>@item.Nombre</td>
                                    <td>@item.Tipo</td>
                                    <td>@item.Tamano</td>
                                    <td>
                                        <button class="btn-delete" type="button"
                                                @onclick="() => EliminarAnexo(item)" disabled="@isProcessing">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="ux-empty">
                                    Sin archivos
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="ux-divider" />

            <div class="ux-nota">
                <strong>Nota:</strong><br />
                El número del expediente de la presente solicitud será notificado al correo electrónico consignado en el presente formulario.
            </div>

            <hr class="ux-divider" />

            <div class="ux-actions-right">
                <button class="ux-button" type="button" @onclick="Finalizar" disabled="@(enviandoCorreo || isProcessing)">
                    @(isProcessing ? "Procesando..." : "Enviar solicitud")
                </button>
            </div>

        </div>

    </div>
</div>

