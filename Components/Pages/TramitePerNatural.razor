              "<img src='https://www.gob.pe/rails/active_storage/representations/redirect/eyJfcmFpbHMiOnsiZGF0YSI6NDk2ODQ0LCJwdXIiOiJibG9iX2lkIn19--1fc9a7807cf6c726e857b951ca1a374a8414a140/eyJfcmFpbHMiOnsiZGF0YSI6eyJmb3JtYXQiOiJwbmciLCJyZXNpemVfdG9fbGltaXQiOltudWxsLDQ4XX0sInB1ciI6InZhcmlhdGlvbiJ9fQ==--830247c4bafe7cadca50817d8559bf1a09e3aa28/paga%20gob.pe.png' style='max-height: 45px; width: auto;' alt='Logo AGRO RURAL' />" +
              "<h3 style='color: #ffffff; margin: 12px 0 0 0; font-size: 1.3rem; font-weight: 600;'>¡Documento Registrado!</h3>" +
          "</div>" +
          "<p style='color: #555555; font-size: 0.95rem; line-height: 1.5; padding: 0 10px;'>Estimado usuario, su documentación ha sido ingresada de forma satisfactoria en la Mesa de Partes Virtual.</p>" +
          "<div style='background-color: #f4f9f5; border: 1px dashed #35af72; border-radius: 6px; padding: 15px; margin: 20px 10px; text-align: left;'>" +
              "<div style='margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;'>" +
                  "<span style='color: #666666; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;'>Código de Trámite:</span>" +
                  "<span style='color: #006432; font-family: monospace; font-size: 1.15rem; font-weight: bold; background: #e8f5e9; padding: 3px 8px; border-radius: 4px;'>" + (resultadoBD?.VAutoGenerado ?? "N/A") + "</span>" +
              "</div>" +
              "<div style='display: flex; justify-content: space-between; align-items: center;'>" +
                  "<span style='color: #666666; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;'>Mail de Seguimiento:</span>" +
                  "<span style='color: #333333; font-size: 0.9rem; font-weight: 600; text-align: right; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;'>" + emailUsuario + "</span>" +
              "</div>" +
          "</div>" +
          "<div style='font-size: 0.8rem; color: #666666; background-color: #fff8e7; border-left: 4px solid #f39c12; padding: 10px; margin: 0 10px 10px 10px; text-align: left; border-radius: 4px;'>📌 <strong>Notificación Enviada:</strong> Se ha despachado el cargo electrónico con el acuse de recibo a la dirección señalada.</div>" +
      "</div>";

        var result = await JS.InvokeAsync<object>("Swal.fire", new
        {
            html = mensajeSwal,
            icon = "success", // Puedes poner "success" para que aparezca el check verde
            confirmButtonText = "Finalizar y Volver",
            confirmButtonColor = "#35af72",
            allowOutsideClick = false,
            allowEscapeKey = false,
            timer = 15000,
            timerProgressBar = true
        });

        // 2. Al llegar aquí, el usuario ya hizo click o el timer expiró.
        // Ahora realizamos la navegación de forma segura.
        // Nav.NavigateTo("/");
    }

    async Task Finalizar()
    {
        // 1. Validaciones
        if (formulario.ICodTipoDoc <= 0 || string.IsNullOrWhiteSpace(formulario.VNroDoc) ||
            string.IsNullOrWhiteSpace(formulario.VNroPagFolios) || formulario.DFecDoc == default ||
            string.IsNullOrWhiteSpace(formulario.VNombreAsunto))
        {
            await JS.InvokeVoidAsync("Swal.fire", "Atención", "Complete los campos obligatorios (*).", "warning");
            return;
        }

        // 2. VALIDACIÓN DEL DOCUMENTO PRINCIPAL
        if (archivo == null || archivo.Contenido == null || archivo.Contenido.Length == 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Atención", "El documento principal es obligatorio.", "warning");
            return;
        }

        try
        {
            formulario.ICodPer = SessionService.UserSession.ICodPer;
            formulario.VEmail = SessionService.UserSession.VEmail;

            // 2. Registro Principal
            formulario.VRutaDoc = await SubirArchivo(archivo.Nombre, archivo.Contenido);
            formulario.BTipo = false;

            var response = await Http.PostAsJsonAsync("api/documentos/registro-tramite-natural", formulario);
            if (!response.IsSuccessStatusCode) throw new Exception(await response.Content.ReadAsStringAsync());

            // Mantenemos esta variable como referencia única
            var resultadoPrincipal = await response.Content.ReadFromJsonAsync<RegistroDocumentoResponseTPN>();

            // 3. Registro Anexos (Opcional)
            if (archivos != null && archivos.Any())
            {
                foreach (var item in archivos)
                {
                    var rutaAnexo = await SubirArchivo(item.Nombre, item.Contenido);
                    var anexo = new TramitePersNaturalDto
                    {
                        ICodPer = formulario.ICodPer,
                        VEmail = formulario.VEmail,
                        ICodTipoDoc = formulario.ICodTipoDoc,
                        VNroDoc = formulario.VNroDoc,
                        VNroPagFolios = formulario.VNroPagFolios,
                        DFecDoc = formulario.DFecDoc,
                        VNombreAsunto = formulario.VNombreAsunto,
                        VReferencia = formulario.VReferencia,
                        VRutaDoc = rutaAnexo,
                        BTipo = true, // Es Anexo
                        ICodAsunto = resultadoPrincipal!.ICodAsunto
                    };
                    await Http.PostAsJsonAsync("api/documentos/registro-tramite-natural", anexo);
                }
            }

            // 4. Éxito
            await MostrarMensajeExito(resultadoPrincipal!);
            Nav.NavigateTo("/Tramitar");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Error al Registrar", ex.Message, "error");
        }
    }


    // Método auxiliar para evitar duplicar código de subida
    private async Task<string> SubirArchivo(string nombre, byte[] contenido)
    {
        using var content = new MultipartFormDataContent();
        using var fileContent = new ByteArrayContent(contenido);

        // El nombre del campo "archivo" debe coincidir con lo que espera tu API
        content.Add(fileContent, "archivo", nombre);

        var response = await Http.PostAsync("api/archivos/subir", content);
        if (!response.IsSuccessStatusCode) throw new Exception($"Error al subir {nombre}");

        var res = await response.Content.ReadFromJsonAsync<RespuestaRuta>();
        return res!.ruta;
    }


}   