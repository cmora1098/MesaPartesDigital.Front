@page "/login"

@layout EmptyLayout
@rendermode InteractiveServer
@inject Models.UserSession Session
@inject NavigationManager Nav  
@inject HttpClient Http
@inject IJSRuntime JS 


@inject MesaPartesDigital.Services.SessionService SessionService
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage

<div class="login-wrapper">

    <aside class="login-left">
        <div class="login-left-content">
            <img src="img/logomax_agrorural.png" alt="Logo Agro Rural" class="login-logo" />

            <h2>Bienvenido a la Plataforma de<br /><strong>Mesa de Partes Digital</strong></h2>

            <p>
                Esta entidad pone a su disposición la Mesa de Partes Digital, un canal diseñado para brindar mayor agilidad, eficiencia y accesibilidad a sus trámites administrativos.
            </p>

            <p>
                En cumplimiento con la Ley N° 31465 (que modifica la Ley N° 27444 del Procedimiento Administrativo General), nuestra plataforma se encuentra habilitada para la presentación de documentos las veinticuatro (24) horas del día, los siete (7) días de la semana.
            </p>

            <div class="alerta-box">
                <span class="alerta-icon">⚠️</span>
                <div class="alerta-text">
                    <strong>Nota importante sobre su recepción:</strong><br />
                    El envío del documento no genera su aceptación automática. La recepción formal será validada únicamente mediante la constancia de ingreso enviada a su correo registrado.
                </div>
            </div>

            <footer class="dev-footer">
                Desarrollado por la Sub Unidad de Tecnologías de la Información.
            </footer>
        </div>
    </aside>

    <main class="login-right">
        <div class="login-container-form">
            <div class="login-box">
                <h3>Acceso al Sistema</h3>
                <p class="login-subtitle">Ingrese sus credenciales para continuar</p>

                @if (!string.IsNullOrEmpty(mensajeAlert))
                {
                    <div class="alert @(esExito ? "alert-success" : "alert-danger")" style="...">
                        @mensajeAlert
                    </div>
                }

                <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                    <div class="input-group">
                        <label for="documento">Número de DNI</label>
                        <input id="documento" type="text" @bind-value="loginModel.Documento" maxlength="12" required />
                    </div>

                    <div class="input-group">
                        <label for="password">Contraseña</label>
                        <input id="password" type="password" @bind-value="loginModel.Password" placeholder="••••••••" required />
                    </div>
                    <!-- captcha -->
                    @* <div class="input-group">
                        <label for="captcha">Verificación de seguridad: <strong>@captchaTexto</strong></label>
                        <input id="captcha" type="number" @bind-value="captchaRespuesta"
                               placeholder="Escribe el resultado" required />
                        <small style="color: #666;">Por favor, resuelve esta suma para continuar.</small>
                    </div> *@


                    <button type="submit" class="btn-login" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span>Validando...</span>
                        }
                        else
                        {

                            <span>Ingresar de forma segura</span>
                        }
                    </button>
                </EditForm>

                <div class="login-actions-secondary" style="...">
                    <button type="button" class="btn-link" @onclick="ProcesarRecuperacionClave" disabled="@isProcessing">
                        ¿No recuerdas tu clave? Genere una nueva aquí
                    </button>
                </div>
            </div>
        </div>
    </main>

</div>
 
@code {
    private LoginDto loginModel = new();
    private string mensajeAlert = string.Empty;
    private bool esExito = false;
    private bool isProcessing = false;
     
    private async Task HandleLogin()
    {
        //  if (captchaRespuesta != (num1 + num2))
        // {
        //     mensajeAlert = "El resultado de la suma es incorrecto. Inténtalo de nuevo.";
        //     esExito = false;
        //     GenerarCaptcha();  
        //     return;
        // }
        isProcessing = true;
        try
        {
            // Llamada al endpoint que definimos en AutenticacionController
            var response = await Http.PostAsJsonAsync("api/autenticacion/login", loginModel);
            var resultado = await response.Content.ReadFromJsonAsync<LoginResultDto>();

            if (resultado?.Exitoso == true)
            {
                 // string json = System.Text.Json.JsonSerializer.Serialize(resultado);
                // Guardar sesión
                // await SessionStorage.SetAsync("user_session", resultado);
                // await SessionStorage.SetAsync("user_session", json);
                // SessionService.UserSession = resultado;
                // Nav.NavigateTo("/dashboard", true);
                // Console.WriteLine("LOGIN: Sesión guardada con clave 'user_session'" + resultado);
                // Console.WriteLine("LOGIN22222222222: Sesión guardada con clave 'user_session'" + json);

                string json = System.Text.Json.JsonSerializer.Serialize(resultado);
                // Guardamos en el navegador
                await JS.InvokeVoidAsync("localStorage.setItem", "user_session", json);

                // Actualizamos el servicio en memoria
                SessionService.UserSession = resultado;

                Nav.NavigateTo("/Tramitar");
            }
            else
            {
                mensajeAlert = resultado?.Mensaje ?? "Error al intentar ingresar.";
            }
           
            // if (!resultado?.Exitoso ?? true) GenerarCaptcha();            // Si falla el login, refresca el captcha para evitar intentos automatizados

        }
        catch (Exception) { mensajeAlert = "Error de conexión con el servidor."; }
        finally { isProcessing = false; }
       
    }

    private async Task ProcesarRecuperacionClave()
    {
        // 1. Validar Captcha (mantenemos tu lógica de seguridad)
        // if (captchaRespuesta != (num1 + num2))
        // {
        //     mensajeAlert = "El resultado de la suma es incorrecto.";
        //     GenerarCaptcha();
        //     return;
        // }

        if (string.IsNullOrWhiteSpace(loginModel.Documento))
        {
            mensajeAlert = "Por favor, ingrese su número de DNI.";
            return;
        }

        isProcessing = true;
        try
        {
            var request = new { Documento = loginModel.Documento, CodigoOtp = (string?)null, TipoAccion = 2 };
            var response = await Http.PostAsJsonAsync("api/autenticacion/credenciales", request);
            var resultado = await response.Content.ReadFromJsonAsync<GestionCredencialesResultDto>();

            if (resultado?.Exitoso == true)
            {
                // AQUÍ ESTÁ EL CAMBIO EN EL FRONT:
                // Usamos el EmailDestino que viene del API para mostrarlo en el Swal
                string emailDestino = resultado.EmailDestino ?? "su correo";
                string mensajeSwal = $"Se ha enviado la nueva contraseña a: <br><strong>{emailDestino}</strong>";

                await JS.InvokeVoidAsync("Swal.fire", "¡Recuperación exitosa!", mensajeSwal, "success");

                // Limpiamos el mensaje de alerta superior si todo salió bien
                mensajeAlert = string.Empty;
            }
            else
            {
                mensajeAlert = resultado?.Mensaje ?? "Error en la solicitud.";
            }
        }
        catch (Exception)
        {
            mensajeAlert = "Error al conectar con el servidor.";
        }
        finally
        {
            isProcessing = false;
            // GenerarCaptcha(); // Refrescamos el captcha tras el intento
        }
    }

