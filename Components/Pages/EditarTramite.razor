    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorArchivo = string.Empty;
        var archivosSeleccionados = e.GetMultipleFiles(10); // Límite máximo de anexos

        foreach (var file in archivosSeleccionados)
        {
            if (file.Size > 20 * 1024 * 1024) // 20MB por archivo
            {
                errorArchivo = $"El archivo {file.Name} supera el límite de 20MB.";
                continue;
            }

            if (!file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                errorArchivo = "Solo se permiten archivos en formato PDF.";
                continue;
            }

            using var stream = file.OpenReadStream(20 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            archivosNuevos.Add(new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = file.ContentType,
                Tamano = $"{file.Size / 1024} KB",
                Contenido = ms.ToArray() // Convertido a byte[] listo para viajar por JSON
            });
        }
        StateHasChanged();
    }

    private void EliminarArchivo(ArchivoAdjunto archi) => archivos.Remove(archi);
    private string? previewUrl;
    private void CerrarPreview() => previewUrl = null;

    private void VerDocumento(AnexoDto anexo)
    {
        // Si anexo.Ruta ya tiene la ruta física completa (ej: C:\MesaDePartesLocal\REGDOC\archivo.pdf),
        // puedes mapearla directamente a través de tu controlador pasando el iCodDoc
        // o apuntando a un endpoint que lea el archivo directamente por su ruta o ID.
        var baseUrl = Configuration["ApiSettings:BaseUrl"] ?? "https://localhost:7100/";

        if (!baseUrl.EndsWith("/"))
            baseUrl += "/";

        previewUrl = $"{baseUrl}api/documentos/ver-archivo-anexo/{anexo.iCodDoc}";
    }

    private async Task EliminarAnexoRegistrado(int iCodDoc, string nombreVisual)
    {
        // Confirmación con SweetAlert2
        var confirmResult = await JSRuntime.InvokeAsync<SweetAlertResult>("Swal.fire", new
        {
            title = $"¿Estás seguro de eliminar el {nombreVisual}?",
            text = "Esta acción dará de baja el documento del trámite.",
            icon = "warning",
            showCancelButton = true,
            confirmButtonText = "Sí, eliminar",
            cancelButtonText = "Cancelar"
        });

        // Validamos si el usuario hizo clic en confirmar (dependiendo de cómo retorne tu SweetAlert)
        // Si usas la estructura estándar de SweetAlert2 en Blazor, validamos la propiedad IsConfirmed o el valor booleano:
        bool confirmado = false;

        if (confirmResult != null)
        {
            // Si confirmResult viene como objeto dinámico o clase de resultado:
            confirmado = confirmResult.IsConfirmed; // O si es directo boolean según tu librería JSInterop
        }

        if (!confirmado) return; // Si canceló, no hacemos nada

        try
        {
            var response = await Http.DeleteAsync($"api/documentos/eliminar-anexo/{iCodDoc}");

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("Swal.fire", "¡Eliminado!", "El anexo se eliminó correctamente.", "success");

                // 🟢 1. Ocultamos el visor integrando limpiando la URL de vista previa
                previewUrl = string.Empty;

                // 2. Recargamos la lista automáticamente para que desaparezca de la tabla
                await CargarAnexos();

                // 3. Forzamos a Blazor a redibujar el componente
                StateHasChanged();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("Swal.fire", "Error", "No se pudo procesar la eliminación en la base de datos.", "error");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Error de red", $"Ocurrió un error: {ex.Message}", "error");
        }
    }

    private List<ArchivoAdjunto> archivosNuevos = new();
   
    private void EliminarArchivoLocal(ArchivoAdjunto archivo)
    {
        archivosNuevos.Remove(archivo);
        StateHasChanged();
    }

    private async Task ActualizarDocumentoAnexos()
    {
        if (!archivosNuevos.Any())
        {
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Aviso", "No hay nuevos anexos por guardar.", "info");
            return;
        }

        try
        {
            // Enviamos la lista de objetos ArchivoAdjunto a la API
            var response = await Http.PostAsJsonAsync($"api/documentos/registrar-anexos/{idAsunto}", archivosNuevos);

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("Swal.fire", "¡Éxito!", "Los anexos se guardaron correctamente.", "success");

                // Limpiamos la lista local de nuevos archivos
                archivosNuevos.Clear();

                // Recargamos la tabla de anexos registrados desde la Base de Datos
                await CargarAnexos();

                StateHasChanged();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("Swal.fire", "Error", "No se pudieron guardar los anexos en la base de datos.", "error");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Error de red", $"Ocurrió un error: {ex.Message}", "error");
        }
    }

    // ******************
    // Actualizar Cambios
    // ****************** 

    private async Task GuardarCambios()
    {
        try
        {
            // 1. Si hay nuevos anexos, los enviamos primero
            if (archivosNuevos.Any())
            {
                var responseAnexos = await Http.PostAsJsonAsync($"api/documentos/registrar-anexos/{idAsunto}", archivosNuevos);

                if (!responseAnexos.IsSuccessStatusCode)
                {
                    var errorContent = await responseAnexos.Content.ReadAsStringAsync();
                    await JSRuntime.InvokeVoidAsync("Swal.fire", "Error", "No se pudieron guardar los nuevos anexos.", "error");
                    return;
                }
            }

            // 2. Ejecutamos el cambio de estado del trámite (de 5 a 1)
            var responseEstado = await Http.PutAsync($"api/documentos/cambiar-estado/{idAsunto}", null);

            if (responseEstado.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("Swal.fire", "¡Éxito!", "Los cambios se guardaron y el trámite fue actualizado correctamente.", "success");

                archivosNuevos.Clear();
                Nav.NavigateTo("/Tramitar");
            }
            else
            {
                // LEER EL MENSAJE REAL QUE MANDA LA API
                var errorServidor = await responseEstado.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("Swal.fire", "Aviso", $"No se pudo actualizar el estado: {errorServidor}", "warning");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("Swal.fire", "Error de red", $"Ocurrió un error inesperado: {ex.Message}", "error");
        }
    }
