    private UserSession Session = new UserSession();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // 1. Verificación de sesión en memoria
                if (SessionService.UserSession == null)
                {
                    var json = await JS.InvokeAsync<string>("localStorage.getItem", "user_session");
                    if (!string.IsNullOrEmpty(json))
                    {
                        SessionService.UserSession = System.Text.Json.JsonSerializer.Deserialize<LoginResultDto>(json);
                    }
                    else
                    {
                        Nav.NavigateTo("/login", true);
                        return; // Salimos si no hay sesión
                    }
                }

                // 2. Carga del historial desde el API
                var userId = SessionService.UserSession?.ICodPer;

                if (userId != null && todosLosTramites.Count == 0)
                {
                    try
                    {
                        var lista = await Http.GetFromJsonAsync<List<TramiteDto>>($"api/documentos/historial/{userId}");

                        if (lista != null)
                        {
                            todosLosTramites = lista;
                            tramitesFiltrados = todosLosTramites;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error al obtener historial: {ex.Message}");
                        // Puedes decidir si quieres mostrar un mensaje de error en la UI aquí
                    }
                }

                // 3. Finalización
                esAutorizado = true;
                cargando = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error crítico en carga: {ex.Message}");
                Nav.NavigateTo("/login", true);
            }
        }
    }
    @* ==========================================
       SECCIÓN: VARIABLES DE ESTADO Y UI
       ========================================== *@
    private bool esAutorizado = false;
    private string pasoActual = "historial";
    private string tipoPersona = string.Empty;
    private string filtroCodigo = "";
    private string filtroEstado = "todos";
     
    @* ==========================================
       SECCIÓN: MÉTODOS DE NAVEGACIÓN Y ACCIONES
       ========================================== *@
    private void CambiarPaso(string nuevoPaso) => pasoActual = nuevoPaso;
    private void SeleccionarNatural() => tipoPersona = "TPersonaNatural";
    private void SeleccionarJuridica() => tipoPersona = "TPersonaJuridica";

    private void Continuar()
    {
        if (!string.IsNullOrWhiteSpace(tipoPersona))
            Nav.NavigateTo($"/Tramitar/{tipoPersona}");
    }

    @* ==========================================
       SECCIÓN: LÓGICA DE DATOS Y PAGINACIÓN
       ========================================== *@
    private int paginaActual = 1;
    private int elementosPorPagina = 5;
    private int totalPaginas => (int)Math.Ceiling((double)tramitesFiltrados.Count / elementosPorPagina);

    private List<TramiteDto> todosLosTramites = new();
    private List<TramiteDto> tramitesFiltrados = new();

    private IEnumerable<TramiteDto> GetTramitesPaginados() =>
        tramitesFiltrados.Skip((paginaActual - 1) * elementosPorPagina).Take(elementosPorPagina);

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void AplicarFiltros()
    {
        // Esto funcionará ahora sobre la lista que viene de la API
        tramitesFiltrados = todosLosTramites.Where(t =>
            (string.IsNullOrEmpty(filtroCodigo) || t.Codigo.Contains(filtroCodigo, StringComparison.OrdinalIgnoreCase)) &&
            (filtroEstado == "todos" || t.Estado.Equals(filtroEstado, StringComparison.OrdinalIgnoreCase))
        ).ToList();

        paginaActual = 1;
    }


    private void EditarTramite(int idAsunto)
    {
        // Redirige a una ruta donde tengas el formulario de carga
        // Asegúrate de pasar el ID para que el formulario cargue los datos existentes
        Nav.NavigateTo($"/EditarTramite/{idAsunto}");
    }
}