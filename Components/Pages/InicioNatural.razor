    async Task Finalizar()
    {
        // 1. Validaciones
        ValidarDocumento();
        ValidarCorreo();

        if (!codigoVerificado || !string.IsNullOrEmpty(errorDocumento) || !string.IsNullOrEmpty(errorCorreo)) return;

        if (archivo == null)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Atención", "El archivo principal es obligatorio.", "warning");
            return;
        }

        try
        {
            List<ArchivoRequest> listaArchivos = new List<ArchivoRequest>();

            // 2. Subir Archivo Principal
            // Aquí debes asegurarte de que 'archivo' (tu variable global) sea de tipo ArchivoAdjunto
            // Si tu variable 'archivo' es un IBrowserFile, cámbiala a tipo ArchivoAdjunto
            var rutaPrincipal = await SubirArchivo(archivo.Nombre, archivo.Contenido);
            listaArchivos.Add(new ArchivoRequest { VRutaDoc = rutaPrincipal, BTipo = true });

            // 3. Subir Anexos (Aquí accedemos a las propiedades de 'item' que es ArchivoAdjunto)
            foreach (var item in archivos)
            {
                // Accedemos a 'item.Nombre' y 'item.Contenido' que definimos en tu clase ArchivoAdjunto
                var rutaAnexo = await SubirArchivo(item.Nombre, item.Contenido);
                listaArchivos.Add(new ArchivoRequest { VRutaDoc = rutaAnexo, BTipo = false });
            }

            formulario.Archivos = listaArchivos;

            // 4. Enviar a la API
            var response = await Http.PostAsJsonAsync("api/documentos/registro-natural", formulario);

            if (!response.IsSuccessStatusCode) throw new Exception(await response.Content.ReadAsStringAsync());

            var resultadoBD = await response.Content.ReadFromJsonAsync<RegistroInicioPerNaturalResponse>();

            await MostrarMensajeExito(resultadoBD!);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Error al Registrar", ex.Message, "error");
        }
    }

    // Método auxiliar para evitar duplicar código de subida
    private async Task<string> SubirArchivo(string nombre, byte[] contenido)
    {
        using var content = new MultipartFormDataContent();
        using var fileContent = new ByteArrayContent(contenido);

        // El nombre del campo "archivo" debe coincidir con lo que espera tu API
        content.Add(fileContent, "archivo", nombre);

        var response = await Http.PostAsync("api/archivos/subir", content);
        if (!response.IsSuccessStatusCode) throw new Exception($"Error al subir {nombre}");

        var res = await response.Content.ReadFromJsonAsync<RespuestaRuta>();
        return res!.ruta;
    }

