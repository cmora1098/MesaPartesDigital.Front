@page "/inicio/natural"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using MesaPartesDigital.Models
   
@using System.Net.Http.Json
@inject HttpClient Http  

@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="ux-bg">
    <div class="ux-container">

        <div class="ux-header">
            <div class="ux-badge-top">Mesa de Partes Digital</div>
            <h1>Persona Natural</h1>
            <p class="ux-description">
                Completa todos los campos para registrar tu documento.
            </p>
        </div>

        <div class="ux-card-form">
            <h2>I. DATOS DEL REMITENTE</h2> 
            <div class="ux-grid-form">
                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="formulario.ICodTipoDocPer" @bind:after="OnTipoDocumentoChange">
                        <option value="0">-- SELECCIONE --</option>
                        <option value="1">DNI</option>
                        <option value="3">CE (Carnet de Extranjería)</option>
                    </select>   
                </div>

                <div class="ux-field">
                    <label>Nro. Documento *</label>
                    <input @bind="formulario.VDocPer"
                           @bind:after="ValidarDocumento"
                           maxlength="@(formulario.ICodTipoDocPer == 1 ? "8" : "10")"
                           onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                           placeholder="@(formulario.ICodTipoDocPer == 1 ? "Ingresar Número de DNI" : "Ingresar Número de Carnet de Extranjería")" />

                    @if (!string.IsNullOrEmpty(errorDocumento))
                    {
                        <span class="ux-error">@errorDocumento</span>
                    }
                </div>

                @if (formulario.ICodTipoDocPer == 1)
                {
                    <div class="ux-field ux-field-button full-width">
                        <button class="ux-btn-primary" @onclick="ValidarDatos">
                            Validar datos
                        </button>
                    </div>
                }

                <div class="ux-field">
                    <label>Apellido Paterno *</label>
                    <input @bind="formulario.VApellidoPaterno" disabled="@bloquearDatos" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Apellido Materno *</label>
                    <input @bind="formulario.VApellidoMaterno" disabled="@bloquearDatos" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Nombres *</label>
                    <input @bind="formulario.VNombres" disabled="@bloquearDatos" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Teléfono *</label>
                    <input @bind="formulario.VTelefono" onkeypress="return event.charCode >= 48 && event.charCode <= 57" />
                </div>

                <div class="ux-field">
                    <label>Correo *</label>
                    <div style="display: flex; flex-wrap: wrap; gap: 10px; width: 100%; text-transform: uppercase;">
                        <input type="email"
                               @bind="formulario.VEmail"
                               @bind:after="ValidarCorreo"
                               placeholder="ejemplo@correo.com"
                               style="flex: 1 1 200px; min-width: 0;"
                               disabled="@(codigoVerificado || enviandoCorreo)" />

                        <button type="button"
                                class="ux-btn-secondary"
                                @onclick="GenerarCodigoVerificacion"
                                style="flex: 0 0 auto; min-width: 140px; white-space: nowrap;"
                                disabled="@(string.IsNullOrEmpty(formulario.VEmail) || !string.IsNullOrEmpty(errorCorreo) || codigoVerificado || enviandoCorreo)">
                            @(enviandoCorreo ? "Enviando..." : "Generar Código")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(errorCorreo))
                    {
                        <span class="ux-error">@errorCorreo</span>
                    }
                    @if (!string.IsNullOrEmpty(mensajeCodigo))
                    {
                        <span style="color: #2e7d32; font-size: 0.85rem; margin-top: 4px; display: block;">@mensajeCodigo</span>
                    }
                </div>

                @if (mostrarCampoCodigo)
                {
                    <div class="ux-field">
                        <label>Ingresa código generado *</label>
                        <div style="position: relative; width: 100%; margin-top: 5px;">
                            <input type="text"
                                   @bind="codigoIngresado"
                                   @bind:after="VerificarCodigo"
                                   maxlength="6"
                                   placeholder="AQUÍ LOS 6 DÍGITOS"
                                   style="width: 100%; padding-right: 40px;"
                                   disabled="@codigoVerificado" />

                            @if (codigoVerificado)
                            {
                                <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #2e7d32; font-weight: bold;">
                                    ✅
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(errorCodigo))
                        {
                            <span class="ux-error" style="display: block; margin-top: 4px;">@errorCodigo</span>
                        }
                    </div>
                }

                <div class="ux-field">
                    <label>Dirección *</label>
                    <input @bind="formulario.VDireccion" placeholder="Ej: Av. Arequipa 123, Dpto. 402, Urb. San Felipe" style="text-transform: uppercase;" />
                    <small class="ux-help">
                        Ingrese vía, número, interior/departamento, urbanización o AA.HH.
                    </small>
                </div>

                <div class="ux-field">
                    <label>Departamento *</label>
                    <select @bind="departamentoSeleccionado" @bind:after="OnDepartamentoChanged">
                        <option value="">-- SELECCIONAR --</option>
                        @if (ListaDepartamentos != null)
                        {
                            @foreach (var dep in ListaDepartamentos)
                            {
                                <option value="@dep.vCodigo" style="text-transform: uppercase;">@dep.vDescripcion</option>
                            }
                        }
                    </select>
                </div>

                <div class="ux-field">
                    <label>Provincia *</label>
                    <select @bind="provinciaSeleccionada" @bind:after="OnProvinciaChanged" disabled="@(string.IsNullOrEmpty(departamentoSeleccionado))">
                        <option value="">-- SELECCIONAR --</option>
                        @if (ListaProvincias != null)
                        {
                            @foreach (var prov in ListaProvincias)
                            {
                                <option value="@prov.vCodigo" style="text-transform: uppercase;">@prov.vDescripcion</option>
                            }
                        }
                    </select>
                </div>

                <div class="ux-field">
                    <label>Distrito *</label>
                    <select @bind="formulario.VCodDistrito" disabled="@(string.IsNullOrEmpty(provinciaSeleccionada))">
                        <option value="">-- SELECCIONAR --</option>
                        @if (ListaDistritos != null)
                        {
                            @foreach (var dist in ListaDistritos)
                            {
                                <option value="@dist.vCodigo" style="text-transform: uppercase;">@dist.vDescripcion</option>
                            }
                        }
                    </select>
                </div>

            </div>
        </div>

        <div class="ux-card-form">
            <h2>II. DATOS DEL DOCUMENTO</h2>
            <div class="ux-grid-form">
                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="formulario.ICodTipoDoc">
                        <option value="0">--SELECCIONAR--</option>
                        @foreach (var doc in listaTiposDocumento)
                        {
                            <option value="@doc.iCodTipoDoc">@doc.vNombreTipoDoc</option>
                        }
                    </select>
                </div>

                <div class="ux-field">
                    <label>Nro Documento *</label>
                    <input placeholder="Ej: CARTA N° 001-2024" @bind="formulario.VNroDoc" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Folio *</label>
                    <input @bind="formulario.VNroPagFolios" placeholder="Ej: 15" onkeypress="return event.charCode >= 48 && event.charCode <= 57" />
                </div>

                <div class="ux-field">
                    <label>Fecha del Documento *</label>
                    <input type="date" @bind="formulario.DFecDoc" />
                </div>

                <div class="ux-field full">
                    <label>Asunto / Sumilla *</label>
                    <textarea maxlength="255" @bind="formulario.VNombreAsunto" placeholder="Ingrese el resumen o asunto del documento..." style="text-transform: uppercase;"></textarea>
                </div>

                <div class="ux-field full">
                    <label>Referencia</label>
                    <input @bind="formulario.VReferencia" placeholder="Ej: Exp. Anterior N° 4521" style="text-transform: uppercase;" />
                </div>
            </div>
        </div>

        <div class="ux-card-form">
            <h2>Documento adjunto</h2>

            <InputFile OnChange="OnFileSelected" accept=".pdf" id="fileUpload" class="hidden-input" />

            <p class="ux-file-hint">
                (Peso máximo: 50MB. Solo se permite archivos en formato PDF)
            </p>

            @if (archivo != null && archivo.Contenido != null && archivo.Contenido.Length > 0)
            {
                <div class="ux-file-info">
                    ✅ <span>@archivo.Nombre</span>
                </div>

                <div class="ux-pdf-preview">
                    <iframe src="@($"data:application/pdf;base64,{Convert.ToBase64String(archivo.Contenido)}")"></iframe>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="ux-error">@error</p>
            }

            @* <br />
            <button type="button" class="ux-btn-secondary" @onclick="ToggleUrl">
                🔗 Agregar URL
            </button>

            @if (mostrarUrl)
            {
                <input class="ux-input-url" @bind="urlIngresada" placeholder="https://..." style="text-transform: uppercase;" />
            } *@
        </div>
         
        <div class="ux-card-form">
            <h2>Anexos</h2>

            @* <InputFile id="fileUploadMulti"
                       multiple class="hidden-input" OnChange="HandleFilesSelected" /> *@
            <InputFile id="fileUploadMulti"
                       multiple class="hidden-input"
                       accept=".pdf"
                       OnChange="HandleFilesSelected" />

            @if (!string.IsNullOrEmpty(errorArchivo))
            {
                <div class="ux-error" style="color: red; margin: 10px 0;">
                    <strong>¡Atención!</strong> @errorArchivo
                </div>
            }
            <p class="ux-file-hint">
                @* (Peso máximo de cada archivo: 20MB)(Formatos permitidos: PDF, DOCX, XLSX, PPT, JPG, PNG y ZIP)(Numero máximo de anexos: 10) *@
                (Peso máximo de cada archivo: 20MB) (Formato permitido: **PDF**) (Número máximo de anexos: 10)
            </p>
             

            <br />

            <div class="ux-table-wrapper">
                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (archivos.Any())
                        {
                            @foreach (var archi in archivos)
                            {
                                <tr>
                                    <td>@archi.Nombre</td>
                                    <td>@archi.Tipo</td>
                                    <td>@archi.Tamano</td>
                                    <td>
                                        <button class="btn-delete" @onclick="() => EliminarArchivo(archi)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="ux-empty">
                                    No hay archivos cargados
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="ux-divider" />

            <div class="ux-nota">
                <strong>Nota:</strong><br />
                El número del expediente de la presente solicitud será notificado al correo electrónico consignado en el presente formulario.
            </div>

            <hr class="ux-divider" />

            <div class="ux-actions">
                <button class="ux-btn-primary" @onclick="Finalizar">
                    Enviar solicitud
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(previewUrl))
        {
            <div class="ux-modal-overlay" @onclick="CerrarPreview">
                <div class="ux-modal-content" @onclick:stopPropagation="true">
                    <button class="ux-close" @onclick="CerrarPreview">✖</button>
                    <div class="ux-iframe-wrapper">
                        <iframe src="@previewUrl"></iframe>
                    </div>
                </div>
            </div>
        }  

    
    </div>
</div>

@code {

    // private RegistroDocumentoRequest formulario = new();
    private InicioPersNaturalDto formulario = new();
    private PersonaNaturalDto? personaConsultada;

    private List<TipoDocumento> listaTiposDocumento = new();

    // *******************
    // DATOS DEL REMITENTE
    // *******************

    private string errorDocumento = "";
    private bool bloquearDatos = true;

    private void OnTipoDocumentoChange()
    {

        formulario.VDocPer = "";
        errorDocumento = "";
        formulario.VApellidoPaterno = "";
        formulario.VApellidoMaterno = "";
        formulario.VNombres = "";
        bloquearDatos = (formulario.ICodTipoDocPer == 0 || formulario.ICodTipoDocPer == 1);
    }

    private void ValidarDocumento()
    {
        errorDocumento = "";

        if (string.IsNullOrWhiteSpace(formulario.VDocPer))
        {
            errorDocumento = "El número de documento es obligatorio.";
            return;
        }

        if (formulario.ICodTipoDocPer == 1) // DNI
        {
            if (formulario.VDocPer.Length != 8)
            {
                errorDocumento = "El DNI debe tener exactamente 8 dígitos numéricos.";
            }
        }
        else if (formulario.ICodTipoDocPer == 3) // CE
        {
            if (formulario.VDocPer.Length > 10)
            {
                errorDocumento = "El Carnet de Extranjería (CE) no puede superar los 10 caracteres.";
            }
        }
    }

    private async Task ValidarDatos()
    {
        errorDocumento = "";

        // 1. Validaciones de formulario (igual que antes)
        if (string.IsNullOrEmpty(formulario.VDocPer))
        {
            errorDocumento = "Debe ingresar un número de documento.";
            return;
        }

        if (formulario.ICodTipoDocPer == 1 && (formulario.VDocPer.Length != 8 || !formulario.VDocPer.All(char.IsDigit)))
        {
            errorDocumento = "DNI inválido.";
            return;
        }

        try
        {
            // 2. Llamada al API (Asegúrate de que la URL sea la correcta)
            string url = $"api/personas/natural?tipoDocumento={formulario.ICodTipoDocPer}&documento={formulario.VDocPer}";

            // Hacemos el llamado esperando el DTO
            var personaEncontrada = await Http.GetFromJsonAsync<PersonaNaturalDto>(url);

            // 3. Lógica de asignación (Si el objeto llega, aunque sea vacío, no será null)
            if (personaEncontrada != null && !string.IsNullOrEmpty(personaEncontrada.vDocPer))
            {
                formulario.ICodPer = personaEncontrada.iCodPer;
                formulario.VApellidoPaterno = personaEncontrada.vApellidoPaterno;
                formulario.VApellidoMaterno = personaEncontrada.vApellidoMaterno;
                formulario.VNombres = personaEncontrada.vNombres;

                bloquearDatos = true;
            }
            else
            {
                // Caso donde el API responde OK pero el objeto está vacío
                LimpiarFormularioPersona("Documento no registrado. Complete sus datos manualmente.");
            }
        }
        catch (HttpRequestException ex)
        {
            // Si el API devuelve 404, entra aquí
            if (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                LimpiarFormularioPersona("Documento no registrado. Complete sus datos manualmente.");
            }
            else
            {
                Console.WriteLine($"[ValidarDatos] 🚨 ERROR: {ex.Message}");
                errorDocumento = "Error de conexión con el servidor.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ValidarDatos] 🚨 ERROR DESCONOCIDO: {ex.Message}");
            errorDocumento = "Documento no registrado. Complete sus datos manualmente.";
            bloquearDatos = false;
            formulario.VApellidoPaterno = "";
            formulario.VApellidoMaterno = "";
            formulario.VNombres = "";
            // errorDocumento = "Error al consultar la base de datos de la entidad.";
        }

        StateHasChanged();
    }

    // Método auxiliar para limpiar los campos y desbloquear
    private void LimpiarFormularioPersona(string mensaje)
    {
        errorDocumento = mensaje;
        formulario.VApellidoPaterno = "";
        formulario.VApellidoMaterno = "";
        formulario.VNombres = "";
        formulario.ICodPer = 0;
        bloquearDatos = false;
    }

    // CORREO  
    private string errorCorreo = "";
    private void ValidarCorreo()
    {
        errorCorreo = "";
        formulario.VEmail = formulario.VEmail?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(formulario.VEmail))
        {
            errorCorreo = "El correo electrónico es obligatorio.";
            return;
        }

        var regexEmail = new System.Text.RegularExpressions.Regex(@"^[^@\s]+@[^@\s]+\.[^@\s]+$");

        if (!regexEmail.IsMatch(formulario.VEmail))
        {
            errorCorreo = "El formato del correo electrónico no es válido.";
        }
    }

    private bool codigoVerificado = false;
    private bool enviandoCorreo = false;
    private string errorCodigo = "";
    private string mensajeCodigo = "";
    private string codigoGeneradoOculto = "";
    private bool mostrarCampoCodigo = false;

    private async Task GenerarCodigoVerificacion()
    {
        errorCodigo = "";
        errorCorreo = "";
        mensajeCodigo = "";
        enviandoCorreo = true;

        try
        {
            // Ya no enviamos un código, solo el correo. El servidor se encarga.
            var response = await Http.PostAsJsonAsync("api/correos/otp", new { Correo = formulario.VEmail });

            if (response.IsSuccessStatusCode)
            {
                mostrarCampoCodigo = true;
                mensajeCodigo = $"Se ha enviado un código de verificación a {formulario.VEmail.ToLower()}.";
            }
            else
            {
                errorCorreo = "No se pudo generar el código.";
            }
        }
        finally
        {
            enviandoCorreo = false;
            StateHasChanged();
        }
    }

    private string codigoIngresado = "";
   
    private async Task VerificarCodigo()
    {
        errorCodigo = "";

        if (string.IsNullOrEmpty(codigoIngresado) || codigoIngresado.Length < 6)
        {
            errorCodigo = "El código debe tener 6 dígitos.";
            return;
        }

        try
        {
            // El objeto 'request' debe coincidir con la estructura del modelo en el API
            var request = new { Correo = formulario.VEmail, Codigo = codigoIngresado };
            var response = await Http.PostAsJsonAsync("api/correos/verificar", request);

            if (response.IsSuccessStatusCode)
            {
                codigoVerificado = true;
                mensajeCodigo = "¡Código Aprobado! ✅ El correo ha sido validado.";
                mostrarCampoCodigo = false; // Ocultamos el campo tras éxito
            }
            else
            {
                codigoVerificado = false;
                errorCodigo = "El código ingresado es incorrecto o ha expirado.";
            }
        }
        catch (Exception ex)
        {
            errorCodigo = "Error de conexión con el servicio de validación.";
            Console.WriteLine($"[Error]: {ex.Message}");
        }

        StateHasChanged();
    }

    // DEPARTAMENTO - PROVINCIA - DISTRITO
    private List<UbigeoModel> ListaDepartamentos = new();
    private List<UbigeoModel> ListaProvincias = new();
    private List<UbigeoModel> ListaDistritos = new();

    // Variables para el binding
    private string departamentoSeleccionado = "";
    private string provinciaSeleccionada = "";

    protected override async Task OnInitializedAsync()
    {
        // Carga inicial de departamentos (sin código padre)
        ListaDepartamentos = await Http.GetFromJsonAsync<List<UbigeoModel>>("api/ubigeo");
        // Carga los tipos de documento al abrir la página
        listaTiposDocumento = await Http.GetFromJsonAsync<List<TipoDocumento>>("api/documentos/tipos-documento");
    }

    private async Task OnDepartamentoChanged()
    {
        // Reiniciar estados
        provinciaSeleccionada = "";
        formulario.VCodDistrito = "";
        ListaProvincias.Clear();
        ListaDistritos.Clear();

        if (!string.IsNullOrEmpty(departamentoSeleccionado))
        {
            ListaProvincias = await Http.GetFromJsonAsync<List<UbigeoModel>>($"api/ubigeo?codigoPadre={departamentoSeleccionado}");
        }
    }

    private async Task OnProvinciaChanged()
    {
        // Reiniciar estados
        formulario.VCodDistrito = "";
        ListaDistritos.Clear();

        if (!string.IsNullOrEmpty(provinciaSeleccionada))
        {
            ListaDistritos = await Http.GetFromJsonAsync<List<UbigeoModel>>($"api/ubigeo?codigoPadre={provinciaSeleccionada}");
        }
    }

    // ******************************************************************
    // DOCUMENTOS

    // Campo de asunto desacoplado para prevenir errores de nombres en el modelo
    private string asuntoDocumento = "";

    // ******************************************************************
    // DOCUMENTOS ADJUNTOS
    // ******************************************************************
    private ArchivoAdjunto archivo = new(); // Ahora 'archivo' es de tu clase personalizada
    private string error = "";
    private string? pdfPreviewUrl;

    private bool mostrarUrl = false;
    private void ToggleUrl() => mostrarUrl = !mostrarUrl;
    private string urlIngresada = "";

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);

            archivo = new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = file.ContentType,
                Tamano = $"{file.Size / 1024} KB",
                Contenido = ms.ToArray(),
                FileBrowser = file
            };
        }
    }

    // ************ 
    // ANEXOS
    // ************
    private List<ArchivoAdjunto> archivos = new();
    private string errorArchivo = "";

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorArchivo = "";

        foreach (var file in e.GetMultipleFiles(10))
        {
            // 1. Validar límite de archivos
            if (archivos.Count >= 10)
            {
                errorArchivo = "Ha alcanzado el límite máximo de 10 archivos.";
                break;
            }

            // 2. Validar duplicados por nombre
            if (archivos.Any(a => a.Nombre == file.Name))
            {
                errorArchivo = $"El archivo '{file.Name}' ya ha sido agregado.";
                continue;
            }

            // 3. Validar tamaño
            if (file.Size > 20 * 1024 * 1024)
            {
                errorArchivo = $"El archivo '{file.Name}' supera los 20MB.";
                continue;
            }

            // 4. Validar formato
            var extension = Path.GetExtension(file.Name).ToLower();
            if (extension != ".pdf")
            {
                errorArchivo = $"El archivo '{file.Name}' no es un PDF válido.";
                continue;
            }

            // Procesar archivo
            using var ms = new MemoryStream();
            await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);

            archivos.Add(new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = extension,
                Tamano = $"{file.Size / 1024} KB",
                Contenido = ms.ToArray(), // Esto es lo que necesitas para subirlo
                FileBrowser = file
            });
        }
    }


    private void EliminarArchivo(ArchivoAdjunto archi) => archivos.Remove(archi);
    private string? previewUrl;
    private void CerrarPreview() => previewUrl = null;
    

    private List<ArchivoAdjunto> listaAnexos = new List<ArchivoAdjunto>();

    private async Task MostrarMensajeExito(RegistroInicioPerNaturalResponse resultadoBD)
    {
