@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@page "/Tramitar/TPersonaJuridica"

@layout MainLayout

@inject IJSRuntime JS
@inject Services.SessionService SessionService
@inject NavigationManager Nav

@inject ProtectedSessionStorage SessionStorage
@inject HttpClient Http


<div class="ux-bg">

    <div class="ux-container">

        <div class="ux-header">
            <div class="ux-badge-top">Mesa de Partes Digital</div>
            <h1>Persona Jurídica</h1>
            <p class="ux-description">
                Completa todos los campos para registrar tu documento.
            </p>
        </div>

        <div class="ux-card-form">
            <h2>I. DATOS DE LA EMPRESA</h2>

            <div class="ux-grid-form">
                <div class="ux-field">
                    <label>RUC *</label>
                    <div class="ux-input-group">
                        <input @bind="formulario.VRucEmpresa" @oninput="OnRucInputChanged" placeholder="Ingrese RUC" maxlength="11"
                               onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                               disabled="@isProcessing" />

                        <button type="button" class="ux-btn-primary" @onclick="ValidarRuc" disabled="@isProcessing">
                            @(isProcessing ? "Validando..." : "Validar")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(rucErrorMsg))
                    {
                        <span class="ux-error">@rucErrorMsg</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Razón Social *</label>
                    <!-- Usamos @bind-Value para asegurar que el valor se guarde en el DTO -->
                    <input @bind="formulario.VRazonSocial"
                           readonly="@bloqueadoRazonSocial" style="text-transform: uppercase;"
                           class="@(bloqueadoRazonSocial ? "ux-readonly" : "")"
                           disabled="@isProcessing" />
                </div>
            </div>
        </div>

        <div class="ux-card-form">
            <h2>III. DATOS DEL DOCUMENTO</h2>
            <div class="ux-grid-form">
                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="formulario.ICodTipoDoc">
                        <option value="0">--SELECCIONAR--</option>
                        @foreach (var doc in listaTiposDocumento)
                        {
                            <option value="@doc.iCodTipoDoc">@doc.vNombreTipoDoc</option>
                        }
                    </select>
                </div>

                <div class="ux-field">
                    <label>Nro Documento *</label>
                    <input placeholder="Ej: 001-2024" @bind="formulario.VNroDoc" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Folio *</label>
                    <input @bind="formulario.VNroPagFolios" maxlength="50" placeholder="Ej: 15" onkeypress="return event.charCode >= 48 && event.charCode <= 57" />
                </div>

                <div class="ux-field">
                    <label>Fecha del Documento *</label>
                    <input type="date" @bind="formulario.DFecDoc" />
                </div>

                <div class="ux-field full">
                    <label>Asunto / Sumilla *</label>
                    <textarea maxlength="255" @bind="formulario.VNombreAsunto" placeholder="Ingrese el resumen o asunto del documento..." style="text-transform: uppercase;"></textarea>
                </div>

                <div class="ux-field full">
                    <label>Referencia</label>
                    <input @bind="formulario.VReferencia" placeholder="Ej: Exp. Anterior N° 4521" style="text-transform: uppercase;" />
                </div>
            </div>
        </div>

        <div class="ux-card-form">
            <h2>Documento adjunto</h2>

            <InputFile OnChange="OnFileSelected" accept=".pdf" id="fileUpload" class="hidden-input" />

            <p class="ux-file-hint">
                (Peso máximo: 50MB. Solo se permite archivos en formato PDF)
            </p>

            @if (archivo != null && archivo.Contenido != null && archivo.Contenido.Length > 0)
            {
                <div class="ux-file-info">
                    ✅ <span>@archivo.Nombre</span>
                </div>

                <div class="ux-pdf-preview">
                    <iframe src="@($"data:application/pdf;base64,{Convert.ToBase64String(archivo.Contenido)}")"></iframe>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="ux-error">@error</p>
            }

            @* <br />
            <button type="button" class="ux-btn-secondary" @onclick="ToggleUrl">
                🔗 Agregar URL
            </button>

            @if (mostrarUrl)
            {
                <input class="ux-input-url" @bind="urlIngresada" placeholder="https://..." style="text-transform: uppercase;" />
            } *@
        </div>


        <div class="ux-card-form">
            <h2>Anexos</h2>

            @* <InputFile id="fileUploadMulti"
                       multiple class="hidden-input" OnChange="HandleFilesSelected" /> *@
            <InputFile id="fileUploadMulti"
                       multiple class="hidden-input"
                       accept=".pdf"
                       OnChange="HandleFilesSelected" />

            @if (!string.IsNullOrEmpty(errorArchivo))
            {
                <div class="ux-error" style="color: red; margin: 10px 0;">
                    <strong>¡Atención!</strong> @errorArchivo
                </div>
            }
            <p class="ux-file-hint">
                @* (Peso máximo de cada archivo: 20MB)(Formatos permitidos: PDF, DOCX, XLSX, PPT, JPG, PNG y ZIP)(Numero máximo de anexos: 10) *@
                (Peso máximo de cada archivo: 20MB) (Formato permitido: **PDF**) (Número máximo de anexos: 10)
            </p>


            <br />

            <div class="ux-table-wrapper">
                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (archivos.Any())
                        {
                            @foreach (var archi in archivos)
                            {
                                <tr>
                                    <td>@archi.Nombre</td>
                                    <td>@archi.Tipo</td>
                                    <td>@archi.Tamano</td>
                                    <td>
                                        <button class="btn-delete" @onclick="() => EliminarArchivo(archi)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="ux-empty">
                                    No hay archivos cargados
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="ux-divider" />

            <div class="ux-nota">
                <strong>Nota:</strong><br />
                El número del expediente de la presente solicitud será notificado al correo electrónico consignado en el presente formulario.
            </div>

            <hr class="ux-divider" />

            <div class="ux-actions">
                <button class="ux-button-secondary" @onclick="ManejarVolver">
                    ← Volver
                </button>

                <button class="ux-btn-primary" @onclick="Finalizar">
                    Enviar solicitud
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(previewUrl))
        {
            <div class="ux-modal-overlay" @onclick="CerrarPreview">
                <div class="ux-modal-content" @onclick:stopPropagation="true">
                    <button class="ux-close" @onclick="CerrarPreview">✖</button>
                    <div class="ux-iframe-wrapper">
                        <iframe src="@previewUrl"></iframe>
                    </div>
                </div>
            </div>
        }



    </div>

</div>


@code {

    // Parámetro para notificar al padre que el usuario quiere volver
    [Parameter] public EventCallback OnVolver { get; set; }

    private async Task ManejarVolver()
    {
        // Intentamos notificar al padre primero
        if (OnVolver.HasDelegate)
        {
            await OnVolver.InvokeAsync();
        }
        else
        {
            // Si no hay padre escuchando (caso de error), redirigimos a la ruta segura
            Nav.NavigateTo("/Tramitar", true);
        }
    }


    private RegTramitePersJuridicaDto formulario = new();
    private PersonaNaturalDto? personaConsultada;

    private string razonSocial = string.Empty;

    // **********************
    // I. DATOS DE LA EMPRESA
    // **********************
    private bool isProcessing = false;
    private bool bloqueadoRazonSocial = true;
    private string rucErrorMsg;

    private async Task ValidarRuc()
    {
        if (string.IsNullOrWhiteSpace(formulario.VRucEmpresa) || formulario.VRucEmpresa.Length != 11)
        {
            rucErrorMsg = "El RUC debe tener 11 dígitos.";
            return;
        }

        isProcessing = true;
        rucErrorMsg = string.Empty;

        try
        {
            var resultado = await Http.GetFromJsonAsync<ContribuyenteDto>($"api/personas/juridica?documento={formulario.VRucEmpresa}");

            if (resultado != null)
            {
                formulario.VRazonSocial = resultado.nombreRazonSocial;
                razonSocial = resultado.nombreRazonSocial;
                bloqueadoRazonSocial = true;
            }
            else
            {
                rucErrorMsg = "No se encontró información para este RUC.";
                bloqueadoRazonSocial = false;
                razonSocial = string.Empty; // Limpiamos si no hay éxito
            }
        }
        catch (Exception)
        {
            //rucErrorMsg = "Error al consultar el servicio.";
            rucErrorMsg = "No se encontró información para este RUC. Ingrese el nombre manualmente.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void OnRucInputChanged(ChangeEventArgs e)
    {
        // Al cambiar el RUC, reseteamos la Razón Social en el formulario
        razonSocial = string.Empty;
        bloqueadoRazonSocial = false;
    }
 
    // ************************
    // II. DATOS DEL DOCUMENTO
    // ************************
    private List<TipoDocumento> listaTiposDocumento = new();

    protected override async Task OnInitializedAsync()
    { 
        // Carga los tipos de documento al abrir la página
        listaTiposDocumento = await Http.GetFromJsonAsync<List<TipoDocumento>>("api/documentos/tipos-documento");
    }

    // *****************
    // DOCUMENTO ADJUNTO
    // *****************
    private ArchivoAdjunto archivo = new(); // Ahora 'archivo' es de tu clase personalizada
    private string error = "";
    private string? pdfPreviewUrl;

    private bool mostrarUrl = false;
    private void ToggleUrl() => mostrarUrl = !mostrarUrl;
    private string urlIngresada = "";

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);

            archivo = new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = file.ContentType,
                Tamano = $"{file.Size / 1024} KB",
                Contenido = ms.ToArray(),
                FileBrowser = file
            };
        }
    }

    // ************
    // ANEXOS
    // ************
    private List<ArchivoAdjunto> archivos = new();
    private string errorArchivo = "";

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorArchivo = "";

        foreach (var file in e.GetMultipleFiles(10))
        {
            // 1. Validar límite de archivos
            if (archivos.Count >= 10)
            {
                errorArchivo = "Ha alcanzado el límite máximo de 10 archivos.";
                break;
            }

            // 2. Validar duplicados por nombre
            if (archivos.Any(a => a.Nombre == file.Name))
            {
                errorArchivo = $"El archivo '{file.Name}' ya ha sido agregado.";
                continue;
            }

            // 3. Validar tamaño
            if (file.Size > 20 * 1024 * 1024)
            {
                errorArchivo = $"El archivo '{file.Name}' supera los 20MB.";
                continue;
            }

            // 4. Validar formato
            var extension = Path.GetExtension(file.Name).ToLower();
            if (extension != ".pdf")
            {
                errorArchivo = $"El archivo '{file.Name}' no es un PDF válido.";
                continue;
            }

            // Procesar archivo
            using var ms = new MemoryStream();
            await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);

            archivos.Add(new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = extension,
                Tamano = $"{file.Size / 1024} KB",
                Contenido = ms.ToArray(), // Esto es lo que necesitas para subirlo
                FileBrowser = file
            });
        }
    }


    private void EliminarArchivo(ArchivoAdjunto archi) => archivos.Remove(archi);
    private string? previewUrl;
    private void CerrarPreview() => previewUrl = null;


    private List<ArchivoAdjunto> listaAnexos = new List<ArchivoAdjunto>();

    private async Task MostrarMensajeExitoJuridica(RegistroDocumentoResponseTPJ resultadoBD)
    {
        // Usamos el MailSeguimiento que viene directamente desde la respuesta del SP
        string mailSeguimiento = resultadoBD?.MailSeguimiento ?? "No disponible";

        string mensajeSwal = "<div style='text-align: center; font-family: Arial, sans-serif;'>" +
          "<div style='background-color: #35af72; margin: -1.25em -1.25em 20px -1.25em; padding: 25px 10px; border-top-left-radius: 5px; border-top-right-radius: 5px;'>" +
              "<img src='https://www.gob.pe/rails/active_storage/representations/redirect/eyJfcmFpbHMiOnsiZGF0YSI6NDk2ODQ0LCJwdXIiOiJibG9iX2lkIn19--1fc9a7807cf6c726e857b951ca1a374a8414a140/eyJfcmFpbHMiOnsiZGF0YSI6eyJmb3JtYXQiOiJwbmciLCJyZXNpemVfdG9fbGltaXQiOltudWxsLDQ4XX0sInB1ciI6InZhcmlhdGlvbiJ9fQ==--830247c4bafe7cadca50817d8559bf1a09e3aa28/paga%20gob.pe.png' style='max-height: 45px; width: auto;' alt='Logo AGRO RURAL' />" +
              "<h3 style='color: #ffffff; margin: 12px 0 0 0; font-size: 1.3rem; font-weight: 600;'>¡Trámite Jurídico Registrado!</h3>" +
          "</div>" +
          "<p style='color: #555555; font-size: 0.95rem; line-height: 1.5; padding: 0 10px;'>Estimado usuario, su documentación empresarial ha sido ingresada de forma satisfactoria en la Mesa de Partes Virtual.</p>" +
          "<div style='background-color: #f4f9f5; border: 1px dashed #35af72; border-radius: 6px; padding: 15px; margin: 20px 10px; text-align: left;'>" +
              "<div style='margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;'>" +
                  "<span style='color: #666666; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;'>Código de Trámite:</span>" +
                  "<span style='color: #006432; font-family: monospace; font-size: 1.15rem; font-weight: bold; background: #e8f5e9; padding: 3px 8px; border-radius: 4px;'>" + (resultadoBD?.VAutoGenerado ?? "N/A") + "</span>" +
              "</div>" +
              "<div style='display: flex; justify-content: space-between; align-items: center;'>" +
                  "<span style='color: #666666; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;'>Mail de Seguimiento:</span>" +
                  "<span style='color: #333333; font-size: 0.9rem; font-weight: 600; text-align: right; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;'>" + mailSeguimiento + "</span>" +
              "</div>" +
          "</div>" +
          "<div style='font-size: 0.8rem; color: #666666; background-color: #fff8e7; border-left: 4px solid #f39c12; padding: 10px; margin: 0 10px 10px 10px; text-align: left; border-radius: 4px;'>📌 <strong>Notificación Enviada:</strong> Se ha despachado el cargo electrónico con el acuse de recibo a la dirección señalada.</div>" +
      "</div>";

        await JS.InvokeAsync<object>("Swal.fire", new
        {
            html = mensajeSwal,
            icon = "success",
            confirmButtonText = "Finalizar y Volver",
            confirmButtonColor = "#35af72",
            allowOutsideClick = false,
            allowEscapeKey = false,
            timer = 15000,
            timerProgressBar = true
        });
    }

    // Método auxiliar para evitar duplicar código de subida
    private async Task<string> SubirArchivo(string nombre, byte[] contenido)
    {
        using var content = new MultipartFormDataContent();
        using var fileContent = new ByteArrayContent(contenido);

        // El nombre del campo "archivo" debe coincidir con lo que espera tu API
        content.Add(fileContent, "archivo", nombre);

        var response = await Http.PostAsync("api/archivos/subir", content);
        if (!response.IsSuccessStatusCode) throw new Exception($"Error al subir {nombre}");

        var res = await response.Content.ReadFromJsonAsync<RespuestaRuta>();
        return res!.ruta;
    }

    async Task Finalizar()
    {
        // 1. Validaciones
        if (string.IsNullOrWhiteSpace(formulario.VNombreAsunto))
        {
            await JS.InvokeVoidAsync("Swal.fire", "Atención", "El nombre del asunto es obligatorio.", "warning");
            return;
        }

        if (archivo == null || archivo.Contenido == null)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Atención", "El archivo principal es obligatorio.", "warning");
            return;
        }

        try
        {
            // 2. Asignación de datos de sesión
            formulario.ICodPer = SessionService.UserSession.ICodPer;
            formulario.VEmail = SessionService.UserSession.VEmail;

            List<ArchivoRequestTPJ> listaArchivos = new List<ArchivoRequestTPJ>();

            // 3. Subir y agregar Archivo Principal
            // EsAnexo = false (0) -> Principal
            var rutaPrincipal = await SubirArchivo(archivo.Nombre, archivo.Contenido);
            listaArchivos.Add(new ArchivoRequestTPJ { VRutaDoc = rutaPrincipal, BTipo = false });

            // 4. Subir y agregar Anexos
            // EsAnexo = true (1) -> Anexo
            foreach (var item in archivos)
            {
                var rutaAnexo = await SubirArchivo(item.Nombre, item.Contenido);
                listaArchivos.Add(new ArchivoRequestTPJ { VRutaDoc = rutaAnexo, BTipo = true });
            }

            formulario.Archivos = listaArchivos;

            // 5. Enviar a la API
            var response = await Http.PostAsJsonAsync("api/documentos/registro-tramite-juridica", formulario);

            if (!response.IsSuccessStatusCode)
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                throw new Exception(errorContent);
            }

            var resultadoBD = await response.Content.ReadFromJsonAsync<RegistroDocumentoResponseTPJ>();

            // 6. Finalización exitosa
            await MostrarMensajeExitoJuridica(resultadoBD!);
            Nav.NavigateTo("/Tramitar");
        }
        catch (Exception ex)
        {
            // Limpiamos el mensaje de error si es un error técnico muy largo del SP
            string msg = ex.Message.Contains("Error:") ? ex.Message.Split("Error:")[1] : ex.Message;
            await JS.InvokeVoidAsync("Swal.fire", "Error al Registrar", msg, "error");
        }
    }

}