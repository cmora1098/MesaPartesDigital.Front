@page "/natural"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using System.IO 

<div class="ux-bg">
    <div class="ux-container">

        <div class="ux-header">
            <div class="ux-badge-top">Mesa de Partes Digital</div>
            <h1>Persona Natural</h1>
            <p class="ux-description">
                Completa los datos del documento para registrar tu solicitud de trámite.
            </p>
        </div>

        <div class="ux-card-form">
            <h2>I. DATOS DEL DOCUMENTO</h2>
            <div class="ux-grid-form">
                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="formulario.ICodTipoDoc">
                        <option value="0">--SELECCIONAR--</option>
                        @foreach (var doc in listaTiposDocumento)
                        {
                            <option value="@doc.iCodTipoDoc">@doc.vNombreTipoDoc</option>
                        }
                    </select>
                </div>

                <div class="ux-field">
                    <label>Nro Documento *</label>
                    <input @bind="formulario.VNroDoc" style="text-transform: uppercase;" />
                </div>

                <div class="ux-field">
                    <label>Folio *</label>
                    <input @bind="formulario.VNroPagFolios" onkeypress="return event.charCode >= 48 && event.charCode <= 57" />
                </div>

                <div class="ux-field">
                    <label>Fecha del Documento *</label>
                    <input type="date" @bind="formulario.DFecDoc" />
                </div>

                <div class="ux-field full">
                    <label>Asunto / Sumilla *</label>
                    <textarea maxlength="255" @bind="asuntoDocumento" style="text-transform: uppercase;"></textarea>
                </div>

                <div class="ux-field full">
                    <label>Referencia</label>
                    <input @bind="formulario.VReferencia" style="text-transform: uppercase;" />
                </div>
            </div>
        </div>

        <div class="ux-card-form">
            <h2>Documento adjunto principal</h2>
            <InputFile OnChange="OnFileSelected" accept=".pdf" id="fileUpload" class="hidden-input" />

            <p class="ux-file-hint">
                (Peso máximo: 50MB. Solo se permiten archivos en formato PDF)
            </p>

            @if (archivoPrincipal != null)
            {
                <div class="ux-file-info">
                    ✅ <span>@archivoPrincipal.Name</span>
                </div>

                @if (!string.IsNullOrEmpty(pdfPreviewUrl))
                {
                    <div class="ux-pdf-preview">
                        <iframe src="@pdfPreviewUrl"></iframe>
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(errorArchivoPrincipal))
            {
                <p class="ux-error">@errorArchivoPrincipal</p>
            }

            <br />
            <button type="button" class="ux-btn-secondary" @onclick="ToggleUrl">
                🔗 Agregar URL
            </button>

            @if (mostrarUrl)
            {
                <input class="ux-input-url" @bind="urlIngresada" placeholder="https://..." />
            }
        </div>

        <div class="ux-card-form">
            <h2>Anexos</h2>
            <InputFile id="fileUploadMulti" OnChange="HandleFilesSelected" multiple class="hidden-input" />

            <p class="ux-file-hint">
                (Peso máximo por anexo: 20MB)(Formatos permitidos: PDF, DOCX, XLSX, PPT, JPG, PNG y ZIP)(Número máximo: 10 anexos)
            </p>

            <br />

            <div class="ux-table-wrapper">
                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (anexosLista.Any())
                        {
                            @foreach (var anexo in anexosLista)
                            {
                                <tr>
                                    <td>@anexo.Nombre</td>
                                    <td>@anexo.Tipo</td>
                                    <td>@anexo.Tamano</td>
                                    <td>
                                        <button type="button" class="btn-delete" @onclick="() => EliminarAnexo(anexo)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="ux-empty">No hay anexos cargados</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="ux-divider" />

            <div class="ux-nota">
                <strong>Nota:</strong><br />
                El número del expediente asignado será notificado al correo electrónico del usuario registrado.
            </div>

            <hr class="ux-divider" />

            <div class="ux-actions">
                <button type="button" class="ux-btn-primary" @onclick="Finalizar">
                    Enviar solicitud
                </button>
            </div>
        </div>

    </div>
</div>

