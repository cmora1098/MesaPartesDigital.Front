    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        errorArchivoPrincipal = "";
        archivoPrincipal = e.File;

        if (archivoPrincipal == null) return;

        if (archivoPrincipal.ContentType != "application/pdf")
        {
            errorArchivoPrincipal = "Solo se permiten archivos en formato PDF.";
            archivoPrincipal = null;
            pdfPreviewUrl = null;
            return;
        }

