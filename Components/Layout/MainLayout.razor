@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@inherits LayoutComponentBase
@inject Services.SessionService SessionService
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

@using System.Timers 
 <header class="topbar">
    <div class="gov-left">
        <img src="img/logo_agrorural.png" class="gov-logo" alt="Logo AgroRural" />
        <div class="gov-divider" aria-hidden="true"></div>
        <div class="gov-title">
            <span class="gov-ministry">Programa de Desarrollo Productivo Agrario Rural</span>
            <span class="gov-system">Mesa de Partes Digital</span>
        </div>
    </div>

    @if (SessionService.UserSession != null)
    {
        <div class="user-menu">
            <div class="session-timer">
                Sesión expira en: <strong>@TimeSpan.FromSeconds(segundosRestantes).ToString(@"mm\:ss")</strong>
            </div>

            <div class="user-info">
                <span class="user-avatar" aria-hidden="true">👤</span>
                <span class="user-name">@SessionService.UserSession.VNombreCompleto</span>
            </div>
            <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar Sesión</button>
        </div>
    }
</header>

@if (mostrarModalExtension)
{
    <div class="modal-backdrop">
        <div class="modal-content" role="dialog" aria-labelledby="modal-title" aria-describedby="modal-desc">
            <h2 id="modal-title">¿Desea continuar con su sesión?</h2>
            <p id="modal-desc">Su sesión está a punto de expirar por inactividad. Haga clic en "Continuar" para extenderla.</p>
            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="ExtenderSesion">Continuar sesión</button>
                <button class="btn btn-secondary" @onclick="CerrarSesion">Cerrar ahora</button>
            </div>
        </div>
    </div>
}

<main @onclick="ResetearTiempo" class="main-wrapper" style="min-height: 100vh;">
    @Body
</main>

@code {
    private Timer? timerInactividad;
    private int segundosRestantes = 600;
    private bool mostrarModalExtension = false;

    protected override void OnInitialized()
    {
        // Iniciamos el temporizador global
        timerInactividad = new Timer(1000);
        timerInactividad.Elapsed += VerificarInactividad;
        timerInactividad.AutoReset = true;
        timerInactividad.Enabled = true;
    }

    private void VerificarInactividad(object? sender, ElapsedEventArgs e)
    {
        InvokeAsync(() =>
        {
            if (segundosRestantes > 0)
            {
                segundosRestantes--;
            }
            else
            {
                mostrarModalExtension = true;
                timerInactividad?.Stop();
            }
            StateHasChanged();
        });
    }

    private void ExtenderSesion()
    {
        segundosRestantes = 600;
        mostrarModalExtension = false;
        timerInactividad?.Start();
    }

    private void ResetearTiempo()
    {
        // Solo reiniciamos si no estamos en el modal
        if (!mostrarModalExtension)
        {
            segundosRestantes = 600;
        }
    }

    private async Task CerrarSesion()
    {
        // Limpiamos todo
        await SessionStorage.DeleteAsync("user_session");
        Nav.NavigateTo("/login", true);
    }

    public void Dispose() => timerInactividad?.Dispose();
}